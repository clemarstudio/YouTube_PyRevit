<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit Usage Chatbox" 
        Width="450" Height="650"
        WindowStartupLocation="CenterScreen" 
        Topmost="True"
        ResizeMode="CanResize">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Settings -->
            <RowDefinition Height="*"/>    <!-- User Question (1x) -->
            <RowDefinition Height="3*"/>   <!-- BIM Response (3x) -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- 1. API SETTINGS -->
        <Expander Header="API Settings &amp; Setup" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="1. Select AI Provider:" Margin="0,0,0,2" FontWeight="Bold"/>
                <ComboBox x:Name="cmb_provider" Margin="0,0,0,10" SelectedIndex="0">
                    <ComboBoxItem Content="Gemini (Google)"/>
                    <ComboBoxItem Content="Claude (Anthropic)"/>
                    <ComboBoxItem Content="OpenAI (GPT)"/>
                    <ComboBoxItem Content="Local AI (Ollama)"/>
                </ComboBox>
                
                <TextBlock Text="2. Your API Key / Local URL:" Margin="0,0,0,2" FontWeight="Bold"/>
                <TextBox x:Name="txt_api_key" Margin="0,0,0,10" TextWrapping="NoWrap" ToolTip="Enter API Key or Local URL (e.g. http://localhost:11434)"/>
                
                <TextBlock Text="3. Model Name:" Margin="0,0,0,2" FontWeight="Bold"/>
                <TextBox x:Name="txt_model" Margin="0,0,0,5" Text="gemini-1.5-flash"/>
                <TextBlock Text="*Common models: gpt-4o, claude-3-5-sonnet-20240620, gemini-1.5-pro" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                
                <Button x:Name="btn_save_config" Content="Save Settings" Margin="0,10,0,0" Height="25"/>
                
                <Separator Margin="0,10"/>
                
                <TextBlock Text="4. Local Knowledge Base (JSON):" Margin="0,0,0,2" FontWeight="Bold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txt_kb_path" Grid.Column="0" Text="revit_knowledge.json" VerticalContentAlignment="Center"/>
                    <Button x:Name="btn_browse_kb" Grid.Column="1" Content="..." Width="30" Margin="5,0,0,0"/>
                </Grid>
                <CheckBox x:Name="chk_use_rag" Content="Use RAG (Search local documentation)" IsChecked="True" Margin="0,5,0,0"/>
            </StackPanel>
        </Expander>

        <!-- 2. USER INPUT (Now Row 1, Height 1*) -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Your Question:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txt_input" Height="100" TextWrapping="Wrap" 
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     FontFamily="Segoe UI" FontSize="13" Padding="5"
                     VerticalContentAlignment="Top"/>
            <TextBlock Text="*Press 'Ask Chatbox' to send. Supports Revit context questions." FontSize="10" Foreground="Gray"/>
        </StackPanel>

        <!-- 3. AI RESPONSE (Now Row 2, Height 3*) -->
        <GroupBox Header="AI Chatbox Response" Grid.Row="2" Margin="0,0,0,10">
            <TextBox x:Name="txt_output" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                     Background="#F9F9F9" FontFamily="Segoe UI" FontSize="13"
                     Padding="5"/>
        </GroupBox>

        <!-- 4. ACTION BUTTONS -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btn_ask" Grid.Column="0" Content="Ask Chatbox" Height="45" 
                    FontWeight="Bold" Background="#4CAF50" Foreground="White" Cursor="Hand"/>
            <Button x:Name="btn_clear" Grid.Column="1" Content="Clear Chat" Width="100" Height="45" 
                    Margin="10,0,0,0"/>
        </Grid>
    </Grid>
</Window>
